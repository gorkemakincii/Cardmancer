# PostgreSQL (Neon) bağlantı URL'i
# Neon'dan aldığın bağlantı string'ini buraya yapıştır
DATABASE_URL="postgresql://username:password@ep-xxxx.region.aws.neon.tech/neondb?sslmode=require"

# Sunucu portu
PORT=3001

# Frontend URL (CORS için)
CLIENT_URL="http://localhost:5173"

# JWT Secret (Phase 2'de auth için)
JWT_SECRET="change-this-to-a-random-secret-string"
